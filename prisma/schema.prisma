generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id                Int       @id @default(autoincrement())
  title             String    @db.VarChar(255)
  slug              String    @unique
  subtitle          String?   @db.VarChar(500)
  content           String
  excerpt           String?   @db.VarChar(500)
  category          String    @db.VarChar(100)
  cover             String?   @db.VarChar(500)
  coverCaption      String?
  coverPhotographer String?   @db.VarChar(255)
  published         Boolean   @default(false)
  publishedAt       DateTime?
  featured          Boolean   @default(false)
  featuredQuote     String?
  isPressRelease    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  author            String?   @db.VarChar(255)
  authorTitle       String?   @db.VarChar(255)
  deletedAt         DateTime? @db.Timestamp(6)
  metaTitle         String?   @db.VarChar(100)
  metaDesc          String?   @db.VarChar(160)
  ogImage           String?   @db.VarChar(500)
  readingTime       Int?      @default(0)
  wordCount         Int?      @default(0)
  tags              String[]  @default([])
  location          String?   @db.VarChar(255)
  country           String?   @db.VarChar(100)
  inlineImages      Json?

  @@unique([slug, deletedAt])
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
  @@index([featured])
  @@index([deletedAt])
  @@index([published, deletedAt])
  @@index([country])
  @@index([tags])
  @@map("posts")
}

model Destination {
  id              String         @id @default(cuid())
  name            String         @unique
  slug            String         @unique
  tagline         String
  description     String
  image           String
  heroImage       String
  highlights      String[]       @default([])
  bestTimeToVisit String
  languages       String[]       @default([])
  currency        String
  published       Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  gallery         GalleryImage[]
  popularParks    PopularPark[]
  safaris         Safari[]

  @@index([slug])
  @@map("destinations")
}

model PopularPark {
  id            String      @id @default(cuid())
  name          String
  description   String
  image         String
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("popular_parks")
}

model Safari {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  destinationId String
  duration      String
  price         Float
  currency      String         @default("USD")
  excerpt       String
  description   String
  image         String
  groupSize     String
  accommodation String
  activities    String[]       @default([])
  includes      String[]       @default([])
  excludes      String[]       @default([])
  highlights    String[]       @default([])
  published     Boolean        @default(true)
  featured      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  gallery       GalleryImage[]
  itinerary     ItineraryDay[]
  destination   Destination    @relation(fields: [destinationId], references: [id])

  @@index([slug])
  @@index([destinationId])
  @@index([published])
  @@index([featured])
  @@map("safaris")
}

model ItineraryDay {
  id            String   @id @default(cuid())
  day           Int
  title         String
  description   String
  safariId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  accommodation String   @default("")
  meals         String[] @default([])
  safari        Safari   @relation(fields: [safariId], references: [id], onDelete: Cascade)

  @@unique([safariId, day])
  @@index([safariId])
  @@map("itinerary_days")
}

model GalleryImage {
  id            String       @id @default(cuid())
  url           String
  alt           String       @default("")
  safariId      String?
  destinationId String?
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  safari        Safari?      @relation(fields: [safariId], references: [id], onDelete: Cascade)

  @@index([safariId])
  @@index([destinationId])
  @@map("gallery_images")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Package Types for Themed Holidays and Local Packages
model PackageType {
  id          String          @id @default(cuid())
  name        String          @unique
  slug        String          @unique
  description String?
  category    PackageCategory // THEMED or LOCAL
  icon        String?         // Lucide icon name
  image       String?         // Cover image
  order       Int             @default(0)
  published   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  safaris     PackageSafari[]

  @@index([slug])
  @@index([category])
  @@index([published])
  @@map("package_types")
}

enum PackageCategory {
  THEMED
  LOCAL
}

// Individual Safaris within Package Types
model PackageSafari {
  id              String              @id @default(cuid())
  title           String
  slug            String              @unique
  packageTypeId   String
  duration        String              // e.g., "5 Days / 4 Nights"
  price           Float
  priceFrom       Boolean             @default(true) // Display as "From $X"
  currency        String              @default("USD")
  excerpt         String              // Short description
  description     String              // Full description
  location        String              // Where it takes place
  image           String              // Main image
  groupSize       String?             // e.g., "2-6 people"
  accommodation   String?             // Type of accommodation
  published       Boolean             @default(true)
  featured        Boolean             @default(false)
  order           Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  highlights      String[]            @default([])
  includes        String[]            @default([])
  excludes        String[]            @default([])
  gallery         PackageGalleryImage[]
  itinerary       PackageItineraryDay[]
  packageType     PackageType         @relation(fields: [packageTypeId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([packageTypeId])
  @@index([published])
  @@index([featured])
  @@map("package_safaris")
}

model PackageItineraryDay {
  id              String        @id @default(cuid())
  day             Int
  title           String
  description     String
  accommodation   String        @default("")
  meals           String[]      @default([])
  activities      String[]      @default([])
  safariId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  safari          PackageSafari @relation(fields: [safariId], references: [id], onDelete: Cascade)

  @@unique([safariId, day])
  @@index([safariId])
  @@map("package_itinerary_days")
}

model PackageGalleryImage {
  id        String        @id @default(cuid())
  url       String
  alt       String        @default("")
  order     Int           @default(0)
  safariId  String
  createdAt DateTime      @default(now())
  safari    PackageSafari @relation(fields: [safariId], references: [id], onDelete: Cascade)

  @@index([safariId])
  @@map("package_gallery_images")
}
